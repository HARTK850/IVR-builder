# Vercel Postgres — מועתקים אוטומטית בעת חיבור ה-DB ב-Vercel Dashboard
# הרץ: vercel env pull .env.local  כדי לקבל את הערכים
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# NODE_ENV (מוגדר אוטומטית ב-Vercel)
NODE_ENV=development
